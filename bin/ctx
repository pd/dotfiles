#!/usr/bin/env bash

set -euo pipefail

display_contexts() {
  kubectl config get-contexts --no-headers |
    awk '{
      if ($1 == "*") { name=$2; current=" *"}
      else { name=$1; current="" }
      print name current
    }'
}

switch_context() {
  local name="$1"
  local matches
  matches="$(kubectl config get-contexts -o name | grep -v -- '-eu$' | grep "$name")"

  if [[ "$(echo "$matches" | wc -l)" -ne 1 ]]; then
    echo "Non-unique context selector: $name" >&2
    echo >&2
    display_contexts
    exit 1
  fi

  kubectl config use-context "$matches"
}

if [[ "$#" -ne 1 ]]; then
  display_contexts
  exit 0
fi

switch_context "$@"
